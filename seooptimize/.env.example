# SEOOptimize v1.0 — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI Provider Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# DeepSeek is the reviewer AI (Module I). Get your key at platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
# Legacy: only needed if you want to use Gemini instead of DeepSeek
# GOOGLE_API_KEY=AIza...

# ── Crawl Settings ───────────────────────────────────────────────────────────
CRAWL_MAX_PAGES=12
CRAWL_MAX_DEPTH=2
CRAWL_DELAY_SECONDS=0.5
CRAWL_USER_AGENT=SEOOptimize/1.0 (+https://seooptimize.local)

# ── Rendering Settings ────────────────────────────────────────────────────────
RENDER_VIEWPORT_WIDTH=1280
RENDER_MOBILE_WIDTH=375
RENDER_TIMEOUT_MS=20000
RENDER_WAIT_UNTIL=domcontentloaded
RENDER_JS_SETTLE_MS=500
RENDER_FULL_PAGE_SCREENSHOTS=false

# ── Quick Audit Settings ─────────────────────────────────────────────────────
QUICK_AUDIT_ENABLED=true
QUICK_AUDIT_MAX_PAGES=8
QUICK_AUDIT_AI_PAGES=3

# ── AI Settings ───────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
DEEPSEEK_MODEL=deepseek-chat
# GEMINI_MODEL=gemini-2.5-flash  # legacy fallback
AI_MAX_RETRIES=3
AI_CONFIDENCE_THRESHOLD=0.65

# ── Cache Settings ────────────────────────────────────────────────────────────
CACHE_DIR=cache
CACHE_ENABLED=true

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_DEBUG=false
